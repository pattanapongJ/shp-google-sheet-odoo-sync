# ---- API security (Odoo must send this in the X-API-Key header) ----
API_KEY=change-me-to-a-long-random-string

# ---- Google Sheets (host-level secret) ----
# Path to the service-account JSON key file. Share the sheet with the
# service account's client_email (Viewer is enough). This MUST live here.
GOOGLE_SA_KEY_FILE=/path/to/service-account.json

# ---- Fallback defaults (normally managed in ODOO, not here) ----
# Odoo sends spreadsheet_id / sheet_range / max_age_days / timezone as query
# params (Sales > Settings > Tax Invoice GSheet Sync). The values below are
# only used when a request omits them, e.g. for a manual `curl` test.
# Spreadsheet ID (the long id in the sheet URL: /spreadsheets/d/<THIS>/edit)
SPREADSHEET_ID= 
# Worksheet/tab name and the A1 range that includes the header row.
SHEET_RANGE='Form Responses 1!A:K'
# Records whose timestamp is older than this many days are filtered OUT.
MAX_AGE_DAYS=7
# Timezone the sheet timestamps are recorded in.
SHEET_TIMEZONE=Asia/Bangkok

# ---- Logging ----
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# LOG_FILE: absolute path to the log file. Leave empty for console-only (dev).
# In production set e.g. /var/log/gsheet-middleware/app.log (the dir is created
# if missing; the process user must be able to write there). Rotates by size.
LOG_FILE=
# Rotation: max size per file (bytes) and how many old files to keep.
LOG_MAX_BYTES=10000000
LOG_BACKUP_COUNT=5

# ---- Column mapping ----
# Maps the SHEET HEADER TEXT (exactly as it appears in row 1) to the
# normalized field name the API returns. Adjust the left-hand keys to
# match your actual (possibly Thai) headers. JSON object.
COLUMN_MAP={"Timestamp":"timestamp","Order Reference":"order_reference","Order Date":"order_date","Amount":"amount","Title":"title","Name":"name","Surname":"surname","Address":"address","Tax ID":"tax_id","Phone":"phone","Email":"email"}
